package global;

fun less(lhs: Any, rhs: Any) = lhs < rhs;
fun greater(lhs: Any, rhs: Any) = lhs > rhs;
fun equal(lhs: Any, rhs: Any) = lhs == rhs;

external fun print(args: Any...): Unit;
external fun len(arr: Array): Int;
external fun make_array(size: Int): Array;

// TODO: Add class template parameters
external class Array {
  external fun get(index: Int): Any;
  external fun set(index: Int, value: Any): Unit;
}