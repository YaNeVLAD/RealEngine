package main;

fun <T> bubbleSort(arr: Array<T>, comp: (T, T) -> Bool) {
	val size = arr.size;

    var i = 0;
    while (i < size - 1) {
        var j = 0;
        while (j < size - i - 1) {
            if (comp(arr[j + 1], arr[j])) {
                var temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
            j++;
        }
        i++;
    }
}