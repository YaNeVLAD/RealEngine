FUN main
    CONST "Hello from RVM!\nNew Line\n\tNew Line wit tab"
    NATIVE "print" 1

    CONST 10
    SET x

    CONST 3.5
    SET y

    GET x
    GET y
    CALL math_magic 2
    SET result

    CONST "Calculation result:"
    GET result
    NATIVE "print" 2

    RETURN

FUN math_magic
    SET x
    SET y

    GET x
    GET y
    MUL

    CONST 100
    ADD

    RETURN