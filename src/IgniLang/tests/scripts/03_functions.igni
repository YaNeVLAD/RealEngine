// EXPECT_OUTPUT:
// 120
// 55
// 42
// END_EXPECT

package program;

fun factorial(n: Int): Int {
    if (n <= 1) {
        return 1;
    }

    return n * factorial(n - 1);
}

fun fibonacci(n: Int): Int {
    if (n <= 1) {
        return n;
    }

    return fibonacci(n - 1) + fibonacci(n - 2);
}

fun main() {
    println(factorial(5));
    println(fibonacci(10));

    val secret = 42;
    val getSecret = fun [secret] (): Int {
        return secret;
    };
    println(getSecret());
}