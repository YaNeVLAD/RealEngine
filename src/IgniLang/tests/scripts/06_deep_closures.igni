// EXPECT_OUTPUT:
// 15
// 30
// 42
// 100
// END_EXPECT

package program;

fun main() {
    var a = 5;

     val outer = fun [a] () {
        var b = 10;

        val inner = fun [a, b] () {
            a = a + b;
            b = b + 5;
        };

        inner();
        println(a); // 5 + 10 = 15

        inner();
        println(a); // 15 + 15 = 30
    };

    outer();

    var secret = 0;
    val setSecret = fun [secret] (v: Int) { secret = v; };
    val getSecret = fun [secret] (): Int = secret;

    setSecret(42);
    println(getSecret()); // 42

    setSecret(100);
    println(getSecret()); // 100
}